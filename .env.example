# FRED (https://fred.stlouisfed.org/docs/api/api_key.html) — required for DGS*, T*YIE, BAML*, FEDFUNDS, SOFR
FRED_API_KEY=

# Alpha Vantage (https://www.alphavantage.co/support/#api-key) — required for FX pairs (EURUSD, etc.)
ALPHA_VANTAGE_API_KEY=

# Financial Modeling Prep (https://financialmodelingprep.com/developer) — required for crypto (BTCUSD, etc.)
FMP_API_KEY=

# Optional. Render injects PORT automatically; only set locally.
PORT=3000
